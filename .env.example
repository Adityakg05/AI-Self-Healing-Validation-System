# LLM Provider: "groq" or "gemini"
LLM_PROVIDER=groq

# API Keys
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=your_username/your_repo_name
GITHUB_BRANCH=main

# App Config
APP_PORT=8000
LOG_FILE=app_logs.txt
MAX_ITERATIONS=10
